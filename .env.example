# -------------------------------------------------------
# .env.example — Copy to .env and fill in your values
# -------------------------------------------------------

# Google Sheets ID (from the URL: /spreadsheets/d/<ID>/edit)
# Leave blank to auto-create a new spreadsheet on first run
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Path to your Google Service Account credentials JSON file
CREDENTIALS_FILE=credentials.json

# Slack webhook for run notifications (optional)
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ENABLE_SLACK_ALERTS=false

# Timezone (informational — scheduler always uses UTC internally)
TIMEZONE=UTC

# Minutes to wait after last market close before fetching closing prices
PRICE_FETCH_DELAY_MINUTES=15
