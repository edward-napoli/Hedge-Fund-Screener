# ============================================================
# Hedge Fund Screener — environment variables
# Copy this file to .env and fill in your values.
# ============================================================

# Google Sheets
GOOGLE_SHEET_ID=                    # Spreadsheet ID from the URL
CREDENTIALS_FILE=credentials.json   # Path to service account JSON

# Slack alerts (optional)
SLACK_WEBHOOK_URL=
ENABLE_SLACK_ALERTS=false

# Scheduler
# Timezone used when displaying times in logs (run times are always computed in UTC)
SCHEDULER_TIMEZONE=America/New_York

# Screener tuning
PRICE_FETCH_DELAY_MINUTES=15

# ── Backtesting & Optimisation ───────────────────────────────

# FMP_API_KEY — removed. FMP free tier no longer supports financial statement
# history (legacy v3 endpoints blocked Aug 2025; stable endpoints require paid
# plan for any symbol). Pipeline now uses EDGAR + yfinance only.

BACKTEST_TOP_N=25
RISK_FREE_RATE=0.04
TRANSACTION_COST_BPS=10
MAX_ADV_PARTICIPATION=0.05
USE_OPTIMIZED_WEIGHTS=false

# ── Risk-Parity & Regime Filter ──────────────────────────────
# WEIGHTING_SCHEME: "equal" or "risk_parity" (inverse-volatility weighting)
WEIGHTING_SCHEME=risk_parity

# REGIME_FILTER: true = reduce equity exposure when SPY < 200-day MA
REGIME_FILTER=true

# Fraction held as cash during risk-off periods (0.0 – 1.0)
REGIME_CASH_FRACTION=0.50

# Lookback window (calendar days) for realised volatility calculation
VOLATILITY_LOOKBACK_DAYS=60

# Maximum weight for any single position in risk-parity mode (0.0 – 1.0)
MAX_SINGLE_POSITION=0.15
